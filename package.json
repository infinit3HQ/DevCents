{
  "name": "devcents-monorepo",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:all": "bash scripts/dev.sh",
    "dev:tmux": "bash scripts/dev-tmux.sh",
    "dev:web": "npm run dev --workspace=apps/web",
    "convex:local": "npm run convex:local --workspace=apps/web",
    "build": "npm run build:web",
    "build:web": "npm run build --workspace=apps/web",
    "test": "npm run test --workspace=apps/web",
    "dev:mcp": "npm run dev --workspace=apps/mcp"
  }
}

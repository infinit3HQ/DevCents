{
  "name": "devcents-monorepo",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "build:web": "npm run build --workspace=apps/web",
    "dev:mcp": "npm run dev --workspace=apps/mcp"
  }
}
